# Copy this file to the repo root as `.env` (git-ignored). It is the single
# source of truth for local development env vars across the monorepo.
NODE_ENV=development
API_PORT=4000
WEB_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
DATABASE_URL=postgresql://ubos:ubos@localhost:5432/ubos?schema=public
LOG_LEVEL=info
