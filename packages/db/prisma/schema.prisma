generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum WorkspaceRole {
  OWNER
  ADMIN
  PRODUCER
  GUEST
}

enum BroadcastSessionStatus {
  DRAFT
  LIVE
  ENDED
}

enum GuestStatus {
  INVITED
  WAITING
  GREEN_ROOM
  CONNECTED
  ON_AIR
  MUTED
  DISCONNECTED
  RECONNECTING
  REJECTED
  REMOVED
}

enum GuestRole {
  HOST
  GUEST
  PRODUCER
}

enum DestinationPlatform {
  YOUTUBE
  FACEBOOK
  TIKTOK
  INSTAGRAM
  LINKEDIN
  TWITCH
  CUSTOM_RTMP
}

enum DestinationStatus {
  DISCONNECTED
  CONNECTED
  LIVE
  ERROR
}

enum ChatPlatform {
  YOUTUBE
  FACEBOOK
  TIKTOK
  INSTAGRAM
  LINKEDIN
  TWITCH
  MOCK
}

enum ChatModerationStatus {
  VISIBLE
  HELD
  HIDDEN
}

enum FollowPlatform {
  YOUTUBE
  INSTAGRAM
  TIKTOK
  TWITCH
  FACEBOOK
  LINKEDIN
}

enum RecordingStatus {
  PENDING
  RECORDING
  PROCESSING
  READY
  FAILED
}

enum SceneType {
  INTRO
  COUNTDOWN
  CAMERA
  INTERVIEW
  SCREEN_SHARE
  BREAK
  OUTRO
  CUSTOM
}

enum SceneSourceType {
  CAMERA
  SCREEN
  MEDIA
  OVERLAY
  BROWSER
  AUDIO
}

enum MediaRouteType {
  GUEST_CAMERA
  GUEST_SCREEN_SHARE
  HOST_CAMERA
  MEDIA_SOURCE
  SCREEN_SHARE
  PLACEHOLDER
}

model User {
  id          String            @id @default(cuid())
  email       String            @unique
  name        String?
  role        UserRole          @default(MEMBER)
  memberships WorkspaceMember[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Workspace {
  id             String             @id @default(cuid())
  name           String
  members        WorkspaceMember[]
  sessions       BroadcastSession[]
  guestInvites   GuestInvite[]
  guests         Guest[]
  guestSessions  GuestSession[]
  deviceInfos    DeviceInfo[]
  sceneSources   SceneSource[]
  mediaRoutes    MediaRoute[]
  destinations   Destination[]
  followProfiles FollowProfile[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(PRODUCER)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model BroadcastSession {
  id              String                 @id @default(cuid())
  workspaceId     String
  title           String
  status          BroadcastSessionStatus @default(DRAFT)
  workspace       Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  guests          Guest[]
  guestInvites    GuestInvite[]
  guestSessions   GuestSession[]
  deviceInfos     DeviceInfo[]
  chatMessages    ChatMessage[]
  followEvents    FollowEvent[]
  recordings      Recording[]
  analyticsEvents AnalyticsEvent[]
  scenes          Scene[]
  sceneSources    SceneSource[]
  mediaRoutes     MediaRoute[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([workspaceId])
  @@index([status])
  @@index([createdAt])
}

model Guest {
  id              String           @id @default(cuid())
  workspaceId     String
  sessionId       String
  inviteId        String?
  displayName     String
  status          GuestStatus      @default(INVITED)
  role            GuestRole        @default(GUEST)
  isMuted         Boolean          @default(false)
  isSpotlighted   Boolean          @default(false)
  privateChatNote String?
  lastSeenAt      DateTime?
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  session         BroadcastSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  invite          GuestInvite?     @relation(fields: [inviteId], references: [id], onDelete: SetNull)
  guestSessions   GuestSession[]
  deviceInfos     DeviceInfo[]
  mediaRoutes     MediaRoute[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([workspaceId])
  @@index([sessionId])
  @@index([workspaceId, sessionId])
  @@index([status])
}

model GuestInvite {
  id          String           @id @default(cuid())
  workspaceId String
  sessionId   String
  token       String           @unique
  displayName String?
  revokedAt   DateTime?
  acceptedAt  DateTime?
  expiresAt   DateTime?
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  session     BroadcastSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  guests      Guest[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([workspaceId])
  @@index([sessionId])
  @@index([workspaceId, sessionId])
  @@index([revokedAt])
}

model GuestSession {
  id             String           @id @default(cuid())
  workspaceId    String
  broadcastId    String
  guestId        String
  connectionId   String           @unique
  status         GuestStatus      @default(GREEN_ROOM)
  joinedAt       DateTime         @default(now())
  disconnectedAt DateTime?
  guest          Guest            @relation(fields: [guestId], references: [id], onDelete: Cascade)
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  broadcast      BroadcastSession @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([broadcastId])
  @@index([guestId])
  @@index([workspaceId, broadcastId])
}

model DeviceInfo {
  id              String           @id @default(cuid())
  workspaceId     String
  broadcastId     String
  guestId         String
  cameraReady     Boolean          @default(false)
  microphoneReady Boolean          @default(false)
  networkReady    Boolean          @default(false)
  userAgent       String?
  guest           Guest            @relation(fields: [guestId], references: [id], onDelete: Cascade)
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  broadcast       BroadcastSession @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([workspaceId])
  @@index([broadcastId])
  @@index([guestId])
  @@index([workspaceId, broadcastId])
}

model Destination {
  id          String              @id @default(cuid())
  workspaceId String
  platform    DestinationPlatform
  label       String
  status      DestinationStatus   @default(DISCONNECTED)
  enabled     Boolean             @default(false)
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([workspaceId])
  @@index([platform])
  @@index([status])
}

model ChatMessage {
  id               String               @id @default(cuid())
  sessionId        String
  authorName       String
  body             String
  platform         ChatPlatform
  moderationStatus ChatModerationStatus @default(VISIBLE)
  session          BroadcastSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt        DateTime             @default(now())

  @@index([sessionId])
  @@index([platform])
  @@index([moderationStatus])
  @@index([createdAt])
}

model FollowProfile {
  id          String         @id @default(cuid())
  workspaceId String
  platform    FollowPlatform
  handle      String
  enabled     Boolean        @default(true)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, platform])
  @@index([workspaceId])
}

model FollowEvent {
  id        String           @id @default(cuid())
  sessionId String
  platform  FollowPlatform
  handle    String
  session   BroadcastSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([sessionId])
  @@index([platform])
  @@index([createdAt])
}

model Recording {
  id        String           @id @default(cuid())
  sessionId String
  status    RecordingStatus  @default(PENDING)
  assetUrl  String?
  session   BroadcastSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([sessionId])
  @@index([status])
}

model AnalyticsEvent {
  id        String           @id @default(cuid())
  sessionId String
  type      String
  payload   Json
  session   BroadcastSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([sessionId])
  @@index([type])
  @@index([createdAt])
}

model Scene {
  id           String           @id @default(cuid())
  broadcastId  String
  name         String
  type         SceneType        @default(CUSTOM)
  order        Int
  isActive     Boolean          @default(false)
  thumbnailUrl String?
  background   Json?
  layout       String?
  sources      Json             @default("[]")
  overlays     Json             @default("[]")
  audioConfig  Json             @default("{}")
  broadcast    BroadcastSession @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  sceneSources SceneSource[]
  mediaRoutes  MediaRoute[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([broadcastId])
  @@index([broadcastId, order])
  @@index([broadcastId, isActive])
}

model SceneSource {
  id          String           @id @default(cuid())
  workspaceId String
  broadcastId String
  sceneId     String
  name        String
  type        SceneSourceType
  order       Int
  isVisible   Boolean          @default(true)
  isLocked    Boolean          @default(false)
  settings    Json             @default("{}")
  transform   Json             @default("{}")
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  broadcast   BroadcastSession @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  scene       Scene            @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([workspaceId])
  @@index([broadcastId])
  @@index([sceneId])
  @@index([workspaceId, broadcastId, sceneId, order])
}


model MediaRoute {
  id          String         @id @default(cuid())
  workspaceId String
  broadcastId String
  guestId     String?
  sourceId    String?
  sceneId     String?
  routeType   MediaRouteType
  displayName String
  isActive    Boolean        @default(true)
  isOnProgram Boolean        @default(false)
  isPinned    Boolean        @default(false)
  isMuted     Boolean        @default(false)
  layoutSlot  String?
  order       Int            @default(0)
  metadata    Json           @default("{}")
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  broadcast   BroadcastSession @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  guest       Guest?         @relation(fields: [guestId], references: [id], onDelete: SetNull)
  scene       Scene?         @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([workspaceId])
  @@index([broadcastId])
  @@index([guestId])
  @@index([sceneId])
  @@index([workspaceId, broadcastId])
  @@index([workspaceId, broadcastId, order])
}
