+import type { FollowPlatform } from '@ubos/shared';
+export class FollowEngineService { private profiles = new Map<string, { workspaceId: string; handles: Partial<Record<FollowPlatform, string>> }>(); getProfile(workspaceId: string) { return this.profiles.get(workspaceId) ?? { workspaceId, handles: {} }; } updateProfile(workspaceId: string, handles: Partial<Record<FollowPlatform, string>>) { const profile = { workspaceId, handles }; this.profiles.set(workspaceId, profile); return profile; } recordEvent(sessionId: string, input: { platform: FollowPlatform; handle: string }) { return { id: crypto.randomUUID(), sessionId, ...input, createdAt: new Date().toISOString() }; } }
