@@ -0,0 +1,3 @@
+import { DestinationStatus, type Destination, type DestinationPlatform } from '@ubos/shared';
+const destinations = new Map<string, Destination>();
+export class DestinationService { list(workspaceId: string) { return [...destinations.values()].filter((d) => d.workspaceId === workspaceId); } create(workspaceId: string, input: { platform: DestinationPlatform; label: string; enabled: boolean }) { const destination = { id: crypto.randomUUID(), workspaceId, platform: input.platform, label: input.label, enabled: input.enabled, status: DestinationStatus.Disconnected }; destinations.set(destination.id, destination); return destination; } update(id: string, patch: Partial<Pick<Destination, 'label' | 'enabled' | 'status'>>) { const current = destinations.get(id); if (!current) return null; const updated = { ...current, ...patch }; destinations.set(id, updated); return updated; } }
