@@ -0,0 +1,3 @@
+import { GuestRole, GuestStatus, type Guest } from '@ubos/shared';
+const guests = new Map<string, Guest>();
+export class GuestService { create(sessionId: string, input: { displayName: string; role?: GuestRole }): Guest { const guest = { id: crypto.randomUUID(), sessionId, displayName: input.displayName, role: input.role ?? GuestRole.Guest, status: GuestStatus.Waiting }; guests.set(guest.id, guest); return guest; } list(sessionId: string) { return [...guests.values()].filter((g) => g.sessionId === sessionId); } update(id: string, patch: Partial<Pick<Guest, 'displayName' | 'status' | 'role'>>) { const guest = guests.get(id); if (!guest) return null; const updated = { ...guest, ...patch }; guests.set(id, updated); return updated; } delete(id: string) { return guests.delete(id); } }
