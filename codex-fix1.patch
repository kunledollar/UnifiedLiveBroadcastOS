+++ b/apps/api/src/services/broadcast-session-service.ts
@@ -0,0 +1,3 @@
+import { BroadcastSessionStatus, type BroadcastSession } from '@ubos/shared';
+const sessions = new Map<string, BroadcastSession>();
+export class BroadcastSessionService { create(input: { workspaceId: string; title: string }): BroadcastSession { const session = { id: crypto.randomUUID(), workspaceId: input.workspaceId, title: input.title, status: BroadcastSessionStatus.Draft, createdAt: new Date().toISOString() }; sessions.set(session.id, session); return session; } get(id: string) { return sessions.get(id) ?? null; } list(workspaceId: string) { return [...sessions.values()].filter((s) => s.workspaceId === workspaceId); } setStatus(id: string, status: BroadcastSessionStatus) { const session = this.get(id); if (!session) return null; const updated = { ...session, status }; sessions.set(id, updated); return updated; } }
